LLM_API_KEY=your-api-key-here
LLM_MODEL=DeepSeek-V4-Pro
LLM_BASE_URL=https://api.ai.beeline.ru/api/v3
LLM_SSL_VERIFY=false
LLM_CERT_PATH=
LLM_MAX_TOKENS=600
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite (default)
DATABASE_URL=sqlite:///prompt_trainer.db
# MSSQL (uncomment for Docker with mssql service)
# DATABASE_URL=mssql+pyodbc://sa:YourStrong!Passw0rd@mssql:1433/master?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# Redis (empty = in-memory)
REDIS_URL=
# REDIS_URL=redis://redis:6379/0

# MSSQL (for Docker)
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

CORS_ORIGINS=
RATE_LIMIT_PER_MINUTE=20
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF=1.0
